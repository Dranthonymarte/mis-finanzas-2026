# ── Service Worker: NUNCA cachear ─────────────────────────────────────
/service-worker.js
  Cache-Control: no-store, no-cache, must-revalidate
  Content-Type: application/javascript

# ── Manifest PWA: sin caché ───────────────────────────────────────────
/manifest.json
  Cache-Control: no-store, no-cache, must-revalidate
  Content-Type: application/manifest+json

# ── App shell: network-first ──────────────────────────────────────────
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  # Preload con rutas absolutas — evita warnings en mobile y Safari
  Link: </config.js>; rel=preload; as=script, </globals-init.js>; rel=preload; as=script, </init.js>; rel=preload; as=script

/
  Cache-Control: no-store, no-cache, must-revalidate
  Link: </config.js>; rel=preload; as=script, </globals-init.js>; rel=preload; as=script, </init.js>; rel=preload; as=script

# ── Módulos JS: cache 1h, revalidar ───────────────────────────────────
# stale-while-revalidate: sirve caché al instante, actualiza en background
/config.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-core.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-nav.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-offline.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-analytics.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-cuentas.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-numpad.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-voice.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-features.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-cuentas-v2.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/app-docs.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/sw-loader.js
  Cache-Control: no-cache, must-revalidate
